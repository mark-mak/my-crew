# ─── Backend (backend/.env) ───────────────────────────────────────────────────

# PostgreSQL connection string (Supabase pooler URL for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secrets — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-different-32-random-characters

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# Must match the deployed Vercel frontend URL in production
FRONTEND_URL=http://localhost:3000


# ─── Frontend (frontend/.env.local) ───────────────────────────────────────────

# Base URL of the Express backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001


# ─── GitHub Actions Secrets (set in repo Settings → Secrets) ─────────────────
#
# RENDER_DEPLOY_HOOK   — Render webhook URL for the backend service
#                        (Settings → Deploy Hook in your Render service dashboard)
#
# GITHUB_TOKEN         — Automatically provided by GitHub Actions (no setup needed)
